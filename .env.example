# ─────────────────────────────────────────────────────────────────────────────
# themis-integrator — configuración de entorno
# Copia este fichero a `.env.local` y ajusta los valores.
# ─────────────────────────────────────────────────────────────────────────────

# Entorno de Themis contra el que integrar. Determina la URL base:
#   development → https://dev.api.gibobs.net   (pruebas / integración)
#   staging     → https://staging.api.gibobs.net
#   production  → https://api.gibobs.com
THEMIS_ENV=development

# Modo mock/sandbox. Con `1` la app simula Themis en local (SQLite) y NO hace
# ninguna llamada de red: puedes ejecutar y demostrar el integrador end-to-end
# sin credenciales. Con `0` se llama a la API real de Themis del THEMIS_ENV.
THEMIS_MOCK=1

# Credenciales M2M por entorno (las entrega Gibobs). Solo necesarias con
# THEMIS_MOCK=0. Se canjean por un token en POST /themis/auth/v1/token.
THEMIS_API_KEY=
THEMIS_API_SECRET=
THEMIS_TOKEN=

# Ruta del fichero SQLite del integrador (su propio almacén). El "backend"
# simulado de Themis (solo en modo mock) vive en <mismo dir>/themis-mock.db.
DATABASE_PATH=./data/integrator.db

# URL de la app de cliente (Estigia) para "cerrar el círculo" del handoff: al
# completar el alta, el integrador ofrece un botón que abre Estigia con el JWT
# del usuario para comprobar que el token funciona. Solo aplica en modo real
# (THEMIS_MOCK=0); en mock el JWT es simulado. Pon la URL completa CON el sufijo
# del estilo de acceso por token, porque el JWT se concatena tal cual al final.
# Hay dos estilos según el tenant:
#   - por ruta:  https://dev.estigia.<managementCode>.gibobs.one/token/
#   - por query: https://dev.estigia.<managementCode>.gibobs.one/?token=
# Cambia el prefijo dev. según el entorno (o usa el dominio personalizado del
# tenant). El managementCode lo entrega Gibobs.
ESTIGIA_BASE_URL=
